################################################################################
# SECRETS & ENVIRONMENT VARIABLES
# Never commit: API keys, tokens, credentials, local overrides
################################################################################
.env
.env.local
.env.*.local
.env.*.private
.claude/settings.local.json      # Local Claude Code settings overrides
credentials.json
*.pem
*.key

################################################################################
# DRUPAL-SPECIFIC
# Ignore generated files, contributed code, and site-specific config
################################################################################
# Site-specific configuration (generated during install, varies per environment)
drupal-site/web/sites/*/settings*.php
drupal-site/web/sites/*/services*.yml

# User-uploaded files (stored locally, not version-controlled)
drupal-site/web/sites/*/files/*
!drupal-site/web/sites/*/files/.gitkeep

# Private files directory
drupal-site/web/sites/*/private/*
!drupal-site/web/sites/*/private/.gitkeep

# Contributed code (managed by composer, not committed)
drupal-site/vendor/
drupal-site/web/core/
drupal-site/web/modules/contrib/
drupal-site/web/themes/contrib/
drupal-site/web/profiles/contrib/
drupal-site/web/libraries/

# Build artifacts
drupal-site/web/sites/*/services.yml.php

################################################################################
# R & SHINY
# Ignore session history, user library, and IDE project files
################################################################################
.Rhistory
.RData
.Ruserdata
*.Rproj
.Rproj.user/
rsconnect/                       # shinyapps.io deployment artifacts
.shiny/                          # Shiny session cache
*.Rcheck/                        # Package check artifacts
*.tar.gz                         # Package archives

################################################################################
# IDE & EDITOR
# Ignore IDE-specific configuration and temporary files
################################################################################
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.sublime-project
.sublime-workspace

################################################################################
# BUILD ARTIFACTS & DEPENDENCIES
# Ignore generated files and dependency folders (managed by package managers)
################################################################################
# Node (if used)
node_modules/
npm-debug.log
yarn-error.log
package-lock.json  # Commit this if managing Node dependencies

# Python (if used)
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/

################################################################################
# DOCKER & LOCAL ENVIRONMENT
# Ignore local overrides and temporary containers
################################################################################
docker-compose.override.yml      # Local docker compose overrides
.docker-compose.local.yml

# DDEV local configuration and database
.ddev/db/drupal.sqlite           # SQLite database (always local, never commit)
.ddev/db/                        # All DDEV database files
.ddev/local/                     # Local DDEV config
.ddev/commands/                  # Local DDEV commands
.ddev/.docker-compose.*.yml      # Generated DDEV compose files

################################################################################
# TESTING ARTIFACTS
# Ignore test outputs and coverage reports
################################################################################
coverage/
.coverage
coverage.xml
htmlcov/
shiny-apps/*/tests/testthat/test_reports/
drupal-site/web/sites/*/files/simpletest/

################################################################################
# OPERATING SYSTEM
# Ignore OS-specific files
################################################################################
.AppleDouble
.LSOverride
*.bak
.Thumbs.db
*.lnk                            # Windows shortcut files
Thumbs.db:encryptable            # Windows alternate data stream
